# Test/CI build: use Cloudflare Turnstile's "always passes, INVISIBLE" test sitekey.
# No checkbox/widget is rendered, a valid dummy token is issued automatically, and
# nothing can intercept the Sign in button click. Pair this with the always-pass test
# SECRET in the API (set quack.turnstile.secret=1x0000000000000000000000000000000AA
# in the test deployment's quack.properties).
#
# Visible variant (renders a checkbox): 1x00000000000000000000AA
# To activate: copy this file to ui/src/.env before building the UI for tests.
REACT_APP_SITE_KEY=1x00000000000000000000BB
REACT_APP_TEST_SITE_KEY=1x00000000000000000000BB
SKIP_PREFLIGHT_CHECK=true
